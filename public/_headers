/*
  # Cloudflare Pages Custom Headers Config
  # 수동 캐시 정화(Purge) 없이, 배포 시 즉각적으로 방문자 웹 브라우저 및 CDN에 최신 버전이 반영되도록 설정합니다.
*/

/*
  Cache-Control:
  - public: 공용 프록시 캐시 허용
  - max-age=0: 브라우저가 매번 원본 서버에 변경 사항이 있는지 재검증하도록 함
  - must-revalidate: 캐시가 만료되면 반드시 재확인하도록 함
*/
/
  Cache-Control: public, max-age=0, must-revalidate

# 정적 에셋(CSS, JS, 이미지, 폰트)들은 고유 해시값(_next/static/...)을 가지므로 1년 동안 강력하게 캐싱해 속도를 최적화(Core Web Vitals 성능 향상)
/_next/static/*
  Cache-Control: public, max-age=31536000, immutable
